# Copy this file to .env and fill values locally. Never commit the real key.
FPT_AI_API_KEY=
FPT_AI_MODEL=
FPT_AI_VISION_MODEL=
FPT_AI_BASE_URL=https://mkp-api.fptcloud.com
FPT_AI_TIMEOUT_SECONDS=20
FPT_AI_MAX_TOKENS=500
FPT_AI_TEMPERATURE=0.2
FPT_AI_MAX_IMAGE_BYTES=5242880

# FPT.AI Console Speech uses a separate key from AI Marketplace.
FPT_SPEECH_API_KEY=
FPT_TTS_URL=https://api.fpt.ai/hmi/tts/v5
FPT_STT_URL=https://api.fpt.ai/hmi/asr/general
FPT_TTS_VOICE=banmai

# Keep false for local demo. Set true in production and configure both values.
APP_AUTH_REQUIRED=false
APP_API_KEYS=
APP_JWT_SECRET=
APP_JWT_TTL_SECONDS=3600
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
